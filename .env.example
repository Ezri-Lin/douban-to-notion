# Douban
DOUBAN_NAME=your_douban_user_name
AUTH_TOKEN=your_douban_auth_token
DOUBAN_API_HOST=frodo.douban.com
DOUBAN_API_KEY=0ac44ae016490db2204ce0a042db2916

# Notion
NOTION_MOVIE_URL=https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_BOOK_URL=https://www.notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TOKEN=secret_xxx
# 或分别配置
# MOVIE_NOTION_TOKEN=secret_xxx
# BOOK_NOTION_TOKEN=secret_xxx

# 可选：数据库名称覆盖
# MOVIE_DATABASE_NAME=Movie
# ACTOR_DATABASE_NAME=Actor
# DIRECTOR_DATABASE_NAME=Director

# 可选：中文标题到 IMDB 英文标题别名（JSON）
# 用于 original_title 缺失时提升检索命中率
# IMDB_TITLE_ALIAS_JSON={\"中文片名A\":\"English Title A\",\"中文片名B\":\"English Title B\"}
# 可选：IMDb 强制覆盖映射（JSON，优先级最高）
# 支持按豆瓣ID、标题或豆瓣URL匹配，value可为tt号或对象{id/imdb_id}
# IMDB_OVERRIDE_JSON={"1305724":"tt0290334","X2":"tt0290334","https://movie.douban.com/subject/1305724/":"tt0290334"}

# 可选：TMDB API Key（用于人物头像兜底）
# TMDB_API_KEY=your_tmdb_api_key
# 可选：指定条目使用固定TMDB ID（用于中文冷门条目）
# 支持按豆瓣ID或标题匹配，value可为数字ID或对象
# 对象可选字段：id/type/imdb_id/original_title/poster_url
# 当未配置 TMDB_API_KEY 时，也可通过 imdb_id/original_title/poster_url 直接回填
# TMDB_ID_OVERRIDE_JSON={"36490015":{"id":"270848","type":"tv"},"护宝寻踪":{"id":"270848","type":"tv","original_title":"The Lost National Treasure"}}

# 可选：douban-imdb-api 地址（测试脚本用）
# WMDB_BASE_URL=https://api.wmdb.tv
